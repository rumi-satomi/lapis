output eDP-1 enable
output HDMI-A-1 disable

gaps inner 0
gaps outer 0

default_border none
default_floating_border none

exec_always /etc/greetd/sway-sync-rotation
exec_always sh -c 'pkill -x wvkbd-keyboard; wvkbd-keyboard &'
exec "gtkgreet -c 'uwsm start sway.desktop > /tmp/uwsm-sway.log 2>&1'; swaymsg exit" 

input type:keyboard {
	xkb_layout de
}

include /etc/sway/config.d/*
