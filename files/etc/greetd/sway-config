gaps inner 0
gaps outer 0

default_border none
default_floating_border none

exec wvkbd-keyboard
exec "waybar -c /etc/greetd/waybar/config.jsonc -s /etc/greetd/waybar/style.css"
exec "gtkgreet -c 'uwsm start sway.desktop > /tmp/uwsm-sway.log 2>&1'; swaymsg exit" 

input type:keyboard {
	xkb_layout de
}

include /etc/sway/config.d/*
