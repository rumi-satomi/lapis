{
	"layer": "top",
	"position": "top",
	"output": ["eDP-1"],
	"include": [
		"/etc/xdg/waybar/modules.json"
	],
	"modules-left": [
		"sway/workspaces"
	],
	"modules-center": [
		"custom/rotate",
		"custom/applauncher"
	],
	"modules-right": [
		"network",
		"pulseaudio",
		"tray",
		"clock",
		"custom/ups"
	],
	"custom/rotate": {
		"format": "⟳",
		"on-click": "echo vertical > /usr/local/etc/sway-mode && sway-sync-rotation",
		"interval": "once",
		"tooltip": false
	}
}
